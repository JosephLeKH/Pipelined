# ── Database ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=pipelined

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
GOOGLE_CLIENT_ID=

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=5
OPENAI_MONTHLY_BUDGET_USD=50.0

# ── GitHub Sync ────────────────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_SYNC_HOUR_UTC=3
GITHUB_REPOS=["SimplifyJobs/Summer2026-Internships"]

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_STANDARD=60/minute
RATE_LIMIT_AI=10/minute
RATE_LIMIT_AUTH=5/minute

# ── Application ────────────────────────────────────────────────────────────────
STALE_APPLICATION_DAYS=14
STALE_LISTING_DAYS=60

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173"]
