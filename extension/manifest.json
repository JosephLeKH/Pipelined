{
  "manifest_version": 3,
  "name": "Pipelined",
  "version": "1.0.0",
  "description": "Track job applications in one click.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://pipelined-zci7h.ondigitalocean.app/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://boards.greenhouse.io/*",
        "https://jobs.lever.co/*",
        "https://jobs.ashbyhq.com/*",
        "https://*.myworkday.com/*",
        "*://www.indeed.com/viewjob*",
        "*://www.glassdoor.com/job-listing/*",
        "*://wellfound.com/jobs/*",
        "*://www.dice.com/job-detail/*",
        "*://app.joinhandshake.com/jobs/*",
        "*://joinhandshake.com/jobs/*",
        "*://remoteok.com/remote-jobs/*"
      ],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html"
  }
}
